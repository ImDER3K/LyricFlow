# LyricFlow Backend — Environment Variables
# Copy this file to .env and fill in your values

# Genius API token (optional but recommended for better lyrics)
# Get one free at: https://genius.com/api-clients
GENIUS_API_TOKEN=fQJ4G8AhfRzr57MIcMl_OXMf8Xuf7wOGBkMA0eRbTV5aduGaxZUw-tOIuTOawKBt

# Whisper model size: tiny | base | small | medium | large
# Recommended: small (better accuracy vs base)
WHISPER_MODEL=small

# SQLite cache database file path
CACHE_DB=cache.db

# Temporary audio files directory
AUDIO_TMP_DIR=tmp_audio

# CORS allowed origins (comma-separated, * for all)
CORS_ORIGINS=*
